{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run typecheck && pnpm run build:workspaces",
    "build:workspaces": "pnpm --recursive --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --recursive --if-present run typecheck"
  },
  "private": true,
  "workspaces": [
    "artifacts/portfolio",
    "artifacts/api-server",
    "artifacts/mockup-sandbox",
    "lib/*",
    "scripts"
  ],
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
